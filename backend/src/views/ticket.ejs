<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NextPlay - Ticket</title>
    <link rel="icon" type="image/x-icon" href="../public/assets/favicon_nextplay.webp">
    <link rel="stylesheet" href="../public/css/ticket.css">
</head>
<body>
    <div class="ticket">
        <div class="ticket__header">
            <div class="ticket__logo">NextPlay</div>
            <div class="ticket__subtitulo">Comprobante de compra N.&deg; <%= id %></div>
        </div>
        <div class="ticket__body">
            <div class="ticket__datos">
                <span>Cliente: <%= nombreCliente %></span>
                <span>Fecha: <%= fecha %></span>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cant.</th>
                        <th>Precio</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>

                <tbody>
                    <% productos.forEach(function(producto) { %>
                    <tr>
                        <td><%= producto.nombre %></td>
                        <td><%= producto.cantidad %></td>
                        <td><%= producto.precioUnitario %></td>
                        <td><%= producto.subtotal %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <div class="ticket__total">
                <span>Total</span>
                <span><%= total %></span>
            </div>
        </div>
        <div class="ticket__footer">Gracias por tu compra en NextPlay</div>

    </div>
</body>
</html>

