<!DOCTYPE html>
<html lang="es" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NextPlay - Admin Dashboard</title>
    <link rel="icon" type="image/x-icon" href="/assets/favicon_nextplay.webp">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <a href="/login" class="navbar__brand">
            <div class="navbar__logo-placeholder">NP</div>
            <span class="navbar__appname">NextPlay</span>
        </a>
        <div class="navbar__right">
            <span class="navbar__alumnos">Alumnos: Llop Tomas &amp; Lopez Juan</span>
            <button class="btn-theme" id="btnTema" title="Cambiar Tema" aria-label="Cambiar Tema">
                <svg id="iconoSol" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1" x2="12" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/>
                    <line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
                <svg id="iconoLuna" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
            </button>
        </div>
    </nav>

    <main class="main-content">
        <div class="container">
            <div class="admin-hero">
                <div class="admin-hero__badge">Back Office</div>
                <h1 style="margin-bottom: 0.75rem;">Panel de Administración</h1>
            </div>

            <section style="margin-bottom: 3rem;">
                <h2 style="margin-bottom: 1rem;">Agregar nuevo producto</h2>
                <div class="card" style="max-width: 680px; margin: 0 auto;">
                    <form action="/admin/productos" method="POST" enctype="multipart/form-data" class="bienvenida-form">
                        <div class="form-group">
                            <label class="form-label" for="nombre">Nombre</label>
                            <input class="form-input" type="text" id="nombre" name="nombre" required />
                        </div>

                        <div class="form-group" style="display:flex; gap:1rem;">
                            <div style="flex:1;">
                                <label class="form-label" for="precio">Precio</label>
                                <input class="form-input" type="number" step="0.01" id="precio" name="precio" required />
                            </div>
                            <div style="flex:1;">
                                <label class="form-label" for="tipo">Tipo</label>
                                <select class="form-input" id="tipo" name="tipo" required>
                                    <option value="videojuego">Videojuego</option>
                                    <option value="consola">Consola</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="imagen">Imagen</label>
                            <input class="form-input" type="file" id="imagen" name="imagen" accept="image/*" />
                        </div>

                        <button class="btn btn-primary btn-lg" type="submit" style="width:100%; margin-top: 0.5rem;">Agregar producto</button>
                    </form>
                </div>
            </section>

            <% const v = productosPorTipo.videojuego || []; %>
            <% const c = productosPorTipo.consola || []; %>

            <div style="display:grid; grid-template-columns: 1fr; gap: 2rem;">
                <section>
                    <h2 style="margin-bottom: 1rem;">Videojuegos</h2>
                    <div style="display:flex; flex-direction:column; gap: 1rem;">
                        <% v.forEach(function(p){ %>
                            <div class="card" style="padding: 1.25rem;">
                                <div style="display:flex; gap: 1rem; align-items:flex-start; flex-wrap:wrap;">
                                    <div style="min-width: 180px; flex: 0;">
                                        <% if (p.imagen) { %>
                                            <img src="http://localhost:3000<%= p.imagen %>" alt="<%= p.nombre %>" style="width:180px; height:120px; object-fit:cover; border-radius:12px; border:1px solid var(--border-color);" />
                                        <% } else { %>
                                            <div style="width:180px; height:120px; border-radius:12px; border:1px dashed var(--border-color); display:flex; align-items:center; justify-content:center; color: var(--text-muted);">Sin imagen</div>
                                        <% } %>
                                    </div>

                                    <div style="flex:1; min-width: 240px;">
                                        <div><strong>Nombre:</strong> <%= p.nombre %></div>
                                        <div><strong>Precio:</strong> <%= p.precio %></div>
                                        <div><strong>Estado:</strong> <%= p.activo ? 'Activo' : 'Desactivado' %></div>

                                        <div style="margin-top: 1rem; display:flex; gap: 0.75rem; flex-wrap:wrap;">
                                            <% if (p.activo) { %>
                                                <form action="/admin/productos/<%= p.id %>/desactivar" method="POST">
                                                    <button class="btn btn-danger btn-sm" type="submit">Desactivar</button>
                                                </form>
                                            <% } else { %>
                                                <form action="/admin/productos/<%= p.id %>/activar" method="POST">
                                                    <button class="btn btn-primary btn-sm" type="submit">Activar</button>
                                                </form>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>

                                <div style="margin-top: 1rem;">
                                    <form action="/admin/productos/<%= p.id %>" method="POST" enctype="multipart/form-data" style="display:grid; grid-template-columns: 1.2fr 0.8fr 1fr; gap: 0.75rem;">
                                        <input class="form-input" type="text" name="nombre" value="<%= p.nombre %>" required />
                                        <input class="form-input" type="number" step="0.01" name="precio" value="<%= p.precio %>" required />
                                        <input class="form-input" type="file" name="imagen" accept="image/*" />

                                        <input type="hidden" name="tipo" value="<%= p.tipo %>" />
                                        <input type="hidden" name="activo" value="<%= p.activo %>" />

                                        <div style="grid-column: 1 / -1; display:flex; justify-content:flex-end; gap:0.75rem;">
                                            <button class="btn btn-secondary" type="submit">Guardar cambios</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        <% }); %>

                        <% if (v.length === 0) { %>
                            <div class="card" style="text-align:center; color: var(--text-muted);">No hay videojuegos cargados.</div>
                        <% } %>
                    </div>
                </section>

                <section>
                    <h2 style="margin-bottom: 1rem;">Consolas</h2>
                    <div style="display:flex; flex-direction:column; gap: 1rem;">
                        <% c.forEach(function(p){ %>
                            <div class="card" style="padding: 1.25rem;">
                                <div style="display:flex; gap: 1rem; align-items:flex-start; flex-wrap:wrap;">
                                    <div style="min-width: 180px; flex: 0;">
                                        <% if (p.imagen) { %>
                                            <img src="http://localhost:3000<%= p.imagen %>" alt="<%= p.nombre %>" style="width:180px; height:120px; object-fit:cover; border-radius:12px; border:1px solid var(--border-color);" />
                                        <% } else { %>
                                            <div style="width:180px; height:120px; border-radius:12px; border:1px dashed var(--border-color); display:flex; align-items:center; justify-content:center; color: var(--text-muted);">Sin imagen</div>
                                        <% } %>
                                    </div>

                                    <div style="flex:1; min-width: 240px;">
                                        <div><strong>Nombre:</strong> <%= p.nombre %></div>
                                        <div><strong>Precio:</strong> <%= p.precio %></div>
                                        <div><strong>Estado:</strong> <%= p.activo ? 'Activo' : 'Desactivado' %></div>

                                        <div style="margin-top: 1rem; display:flex; gap: 0.75rem; flex-wrap:wrap;">
                                            <% if (p.activo) { %>
                                                <form action="/admin/productos/<%= p.id %>/desactivar" method="POST">
                                                    <button class="btn btn-danger btn-sm" type="submit">Desactivar</button>
                                                </form>
                                            <% } else { %>
                                                <form action="/admin/productos/<%= p.id %>/activar" method="POST">
                                                    <button class="btn btn-primary btn-sm" type="submit">Activar</button>
                                                </form>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>

                                <div style="margin-top: 1rem;">
                                    <form action="/admin/productos/<%= p.id %>" method="POST" enctype="multipart/form-data" style="display:grid; grid-template-columns: 1.2fr 0.8fr 1fr; gap: 0.75rem;">
                                        <input class="form-input" type="text" name="nombre" value="<%= p.nombre %>" required />
                                        <input class="form-input" type="number" step="0.01" name="precio" value="<%= p.precio %>" required />
                                        <input class="form-input" type="file" name="imagen" accept="image/*" />

                                        <input type="hidden" name="tipo" value="<%= p.tipo %>" />
                                        <input type="hidden" name="activo" value="<%= p.activo %>" />

                                        <div style="grid-column: 1 / -1; display:flex; justify-content:flex-end; gap:0.75rem;">
                                            <button class="btn btn-secondary" type="submit">Guardar cambios</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        <% }); %>

                        <% if (c.length === 0) { %>
                            <div class="card" style="text-align:center; color: var(--text-muted);">No hay consolas cargadas.</div>
                        <% } %>
                    </div>
                </section>
            </div>
        </div>

        <script>
            const btnTema = document.getElementById('btnTema');
            const root = document.documentElement;

            const TEMA_KEY = 'nextplay_tema';
            const NOMBRE_KEY = 'nextplay_nombre';

            const actualizarIconoTema = (tema) => {
                const sol = document.getElementById('iconoSol');
                const luna = document.getElementById('iconoLuna');
                if (!sol || !luna) return;
                if (tema === 'dark') {
                    sol.style.display = 'block';
                    luna.style.display = 'none';
                } else {
                    sol.style.display = 'none';
                    luna.style.display = 'block';
                }
            };

            const aplicarTemaPersistido = () => {
                const temaGuardado = localStorage.getItem(TEMA_KEY) || 'light';
                if (temaGuardado === 'light' || temaGuardado === 'dark') {
                    root.setAttribute('data-theme', temaGuardado);
                    actualizarIconoTema(temaGuardado);
                }
            };

            aplicarTemaPersistido();

            btnTema?.addEventListener('click', () => {
                const current = root.getAttribute('data-theme') || 'light';
                const nuevoTema = current === 'light' ? 'dark' : 'light';
                root.setAttribute('data-theme', nuevoTema);
                localStorage.setItem('nextplay_tema', nuevoTema);
            });

            const obtenerNombreAdmin = () => {
                return sessionStorage.getItem(NOMBRE_KEY) || null;
            };

            // Modal de confirmación para activar/desactivar (baja lógica / reactivación)
            const modal = document.createElement('div');
            modal.className = 'modal-overlay';
            modal.innerHTML = `
                <div class="modal">
                    <div class="modal-icon" style="width:56px; height:56px; border-radius:18px; margin:0 auto 1rem; background: linear-gradient(135deg, var(--violeta), var(--celeste)); display:flex; align-items:center; justify-content:center;">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:28px; height:28px; color:#fff;">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    </div>
                    <h3 class="modal__title" style="text-align:center; margin-bottom:0.5rem;">Confirmar</h3>
                    <p class="modal__body" id="modalTexto" style="text-align:center;">¿Estás seguro?</p>
                    <div class="modal__actions">
                        <button class="btn btn-outline" id="btnCancelarModal" type="button">Cancelar</button>
                        <button class="btn btn-primary" id="btnConfirmarModal" type="button">Confirmar</button>
                    </div>
                </div>
            `;
            document.body.appendChild(modal);

            let accion = null;
            const btnCancelarModal = modal.querySelector('#btnCancelarModal');
            const btnConfirmarModal = modal.querySelector('#btnConfirmarModal');

            const abrirModal = (texto, form) => {
                accion = form;
                modal.classList.add('visible');
                const textoEl = modal.querySelector('#modalTexto');
                if (textoEl) textoEl.textContent = texto;
            };

            const cerrarModal = () => {
                modal.classList.remove('visible');
                accion = null;
            };

            btnCancelarModal?.addEventListener('click', cerrarModal);
            modal?.addEventListener('click', (e) => {
                if (e.target === modal) cerrarModal();
            });
            btnConfirmarModal?.addEventListener('click', async () => {
                if (accion) {
                    btnConfirmarModal.textContent = 'Procesando...';
                    btnConfirmarModal.style.pointerEvents = 'none';
                    try {
                        const response = await fetch(accion.accion, {
                            method: accion.method || 'POST',
                            body: new FormData(accion)
                        });

                        if (response.ok || response.redirected) {
                            window.location.reload(true);
                        } else {
                            accion.submit();
                        }
                    } catch (error){
                        console.error('Error al realizar la peticion:',error);
                        accion.submit();
                    }
                }else{
                    cerrarModal();
                }
            });

            // Hook: reemplazar submit directo de los forms por modal
            document.querySelectorAll('form[action$="/desactivar"], form[action$="/activar"]').forEach((form) => {
                form.addEventListener('submit', (e) => {
                    e.preventDefault();
                    const esDesactivar = form.getAttribute('action')?.includes('/desactivar');
                    abrirModal(esDesactivar ? '¿Está seguro de eliminar el producto? (baja lógica)' : '¿Está seguro de activar el producto? ¿Confirmar acción?', form);
                });
            });
        </script>
    </main>
</body>
</html>

